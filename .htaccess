<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.nextdigihome\.com$ [NC]
  RewriteRule ^ https://nextdigihome.com%{REQUEST_URI} [R=301,L,NE]

  RewriteRule ^contact-us/?$ https://nextdigihome.com/contact [R=301,L,NE]
  RewriteRule ^home/?$ https://nextdigihome.com/ [R=301,L,NE]
  RewriteRule ^events/feed/?$ https://nextdigihome.com/blog [R=301,L,NE]
  RewriteRule ^by-failing-to-prepare-you-are-preparing-to-fail/?$ https://nextdigihome.com/blog [R=301,L,NE]
  RewriteRule ^by-failing-to-prepare-you-are-preparing-to-fail/feed/?$ https://nextdigihome.com/blog [R=301,L,NE]
  RewriteRule ^dont-find-fault-find-a-remedy/?$ https://nextdigihome.com/blog [R=301,L,NE]
  RewriteRule ^my-best-advice-to-entrepreneurs-is-this-forget-about-making-mistakes-just-do-it/?$ https://nextdigihome.com/blog [R=301,L,NE]
  RewriteRule ^simplicity-is-the-ultimate-sophistication/?$ https://nextdigihome.com/blog [R=301,L,NE]
  RewriteRule ^program/?$ https://nextdigihome.com/services [R=301,L,NE]
  RewriteRule ^payment-confirmed/?$ https://nextdigihome.com/checkout/success [R=301,L,NE]
  RewriteRule ^downloads/?$ https://nextdigihome.com/products [R=301,L,NE]
  RewriteRule ^downloads/category/.*$ https://nextdigihome.com/products [R=301,L,NE]
  RewriteRule ^downloads/tag/.*$ https://nextdigihome.com/products [R=301,L,NE]
  RewriteRule ^downloads/([^/]+)/?$ https://nextdigihome.com/products/$1 [R=301,L,NE]
  RewriteRule ^\*$ https://nextdigihome.com/ [R=301,L,NE]

  RewriteRule ^wp-json/? - [G,L]
  RewriteRule ^wp-content/? - [G,L]
  RewriteRule ^wp-admin/? - [G,L]
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml
  AddOutputFilterByType BROTLI_COMPRESS text/javascript application/javascript application/x-javascript
  AddOutputFilterByType BROTLI_COMPRESS application/json application/ld+json application/xml application/rss+xml
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
  AddOutputFilterByType BROTLI_COMPRESS font/ttf font/otf font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/ttf font/otf font/woff font/woff2 application/font-woff application/font-woff2

  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  Header append Vary Accept-Encoding
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|svg|png|jpg|jpeg|webp|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
